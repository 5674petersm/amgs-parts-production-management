# SQL Server (Google Cloud)
DB_SERVER=your.gcp.sql.ip
DB_PORT=1433
DB_NAME=minimrp2025
DB_USER=
DB_PASSWORD=
DB_ENCRYPT=true
# Required when DB_SERVER is an IP address (common on GCP). Use false only if you connect by hostname with a valid cert.
DB_TRUST_SERVER_CERTIFICATE=true

# Plant-local timestamp (IANA timezone, e.g. America/Chicago)
PLANT_TIMEZONE=America/Chicago

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://production.advmgs.com

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
# Authorized redirect URI: https://production.advmgs.com/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Restrict sign-in to your Workspace domain (e.g. advmgs.com)
AUTH_ALLOWED_DOMAIN=advmgs.com

# Role assignments (comma-separated Google account emails)
# Everyone else in AUTH_ALLOWED_DOMAIN is an Operator.
AUTH_ADMIN_EMAILS=admin@advmgs.com
AUTH_ENGINEER_EMAILS=engineer@advmgs.com

# Final-station alert recipients (comma-separated; can be a Google Group)
ENGINEERING_NOTIFY_EMAILS=production-engineering@advmgs.com

# Gmail notifications (service account domain-wide delegation required)
# From address shown to recipients (must be a configured send-as alias)
GMAIL_SEND_AS=MRPsystem@advmgs.com
# Fallback display name if Gmail send-as settings cannot be read
GMAIL_FROM_NAME=MRP System
# Primary mailbox that owns the send-as alias (required for aliases)
GMAIL_IMPERSONATE_USER=your.name@advmgs.com

# Easiest option: path to the downloaded JSON key file (keep this file out of git)
# 3. Add the service account email as a Content manager on the Shared drive (not just the folder)
# 4. Folder ID from: https://drive.google.com/drive/folders/FOLDER_ID
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=secrets/google-drive-service-account.json
GOOGLE_DRIVE_PARENT_FOLDER_ID=
